{
  "expo": {
    "name": "Mary App",
    "slug": "citizen-complaint-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/santamarialogoapp.jpg",
    "scheme": "citizencomplaintapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.santamaria.citizencomplaint",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload valid identification during registration and attach images to complaints.",
        "NSCameraUsageDescription": "This app needs access to your camera to capture identification documents and take photos for complaints.",
        "NSPhotoLibraryAddUsageDescription": "This app needs access to save photos to your library.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to record videos for complaints.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "notification": {
        "icon": "./assets/images/santamarialogoapp.jpg",
        "color": "#346739",
        "androidMode": "default"
      },
      "adaptiveIcon": {
        "backgroundColor": "#10B981",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lean_kurt_escano.citizencomplaintapp"
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/santamarialogoapp.jpg",
          "color": "#346739",
          "sounds": []
        }
      ],
      "./plugins/greenTheme",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/santamarialogoapp.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#346739",
          "dark": {
            "backgroundColor": "#346739"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photo library to upload valid identification during registration and attach images to complaints.",
          "cameraPermission": "This app needs access to your camera to capture identification documents and take photos for complaints.",
          "microphonePermission": "This app needs access to your microphone to record videos for complaints."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "803edf0b-f96a-4f5c-96db-7ac1fe268656"
      }
    },
    "owner": "lean_kurt_escano"
  }
}
